<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cyber Justice: 5 Sins of Neon</title>
    <style>
        :root {
            --neon-blue: #00d2ff;
            --neon-pink: #ff007f;
            --neon-green: #39ff14;
            --neon-gold: #ffcf00;
            --bg-deep: #020408;
            --glass: rgba(255, 255, 255, 0.05);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            margin: 0; background: var(--bg-deep); color: #fff;
            font-family: 'Segoe UI', Roboto, Helvetica, sans-serif;
            height: 100vh; width: 100vw; overflow: hidden;
            display: flex; flex-direction: column;
        }

        /* --- VISUAL STAGE --- */
        #stage {
            flex: 1; position: relative;
            background: radial-gradient(circle at 50% 30%, #1a1f35 0%, #000 100%);
            display: flex; justify-content: center; align-items: flex-end;
            overflow: hidden;
        }

        .char-img {
            height: 90%; width: auto; position: absolute; bottom: -5px;
            transition: all 0.5s ease-out; z-index: 2;
        }
        .char-img.hidden { opacity: 0; transform: translateY(50px) scale(0.95); }
        .char-img.active { opacity: 1; transform: translateY(0) scale(1); }

        /* --- UI PANEL --- */
        #ui-panel {
            height: 55vh; background: linear-gradient(to bottom, transparent, #000 15%);
            display: flex; flex-direction: column; z-index: 10; padding: 0 20px 20px 20px;
        }

        #status-bar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 5px; border-bottom: 1px solid rgba(0, 210, 255, 0.2);
        }

        .hp-slots { display: flex; gap: 8px; }
        .hp-node { 
            width: 14px; height: 14px; border: 2px solid var(--neon-blue); 
            border-radius: 3px; transform: rotate(45deg); transition: 0.3s;
        }
        .hp-node.active { background: var(--neon-blue); box-shadow: 0 0 10px var(--neon-blue); }

        #dialogue-container {
            flex: 1; margin-top: 15px; background: rgba(5, 10, 20, 0.9);
            border-radius: 20px; border: 1px solid rgba(255,255,255,0.05);
            padding: 25px; overflow-y: auto; position: relative;
        }

        #speaker {
            font-size: 11px; font-weight: 900; letter-spacing: 3px;
            color: var(--neon-pink); margin-bottom: 12px; text-transform: uppercase;
        }

        #message {
            font-size: 16px; line-height: 1.9; color: #eef2f7;
            white-space: pre-wrap;
        }

        /* --- CONTROLS --- */
        #controls { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 15px; }
        .ctrl-btn {
            background: var(--glass); border: 1px solid rgba(255,255,255,0.1);
            color: #fff; padding: 18px 0; border-radius: 15px;
            font-size: 11px; font-weight: 800; text-transform: uppercase;
            letter-spacing: 1px;
        }
        .ctrl-btn:active { background: #fff; color: #000; }
        .btn-objection { border-color: var(--neon-pink); color: var(--neon-pink); }
        .btn-press { border-color: var(--neon-green); color: var(--neon-green); }

        /* --- EVIDENCE MODAL --- */
        #modal-evidence {
            position: fixed; inset: 0; background: #000; z-index: 100;
            display: none; flex-direction: column; padding: 30px;
        }
        .ev-scroll { flex: 1; overflow-y: auto; margin: 20px 0; }
        .ev-card {
            background: #0a0c10; border: 1px solid #1a1f26;
            padding: 15px; border-radius: 15px; margin-bottom: 15px;
            display: flex; gap: 15px; align-items: center;
        }
        .ev-card:active { border-color: var(--neon-blue); background: #0d1520; }

        /* --- SHOUT EFFECTS --- */
        #shout-overlay {
            position: fixed; inset: 0; z-index: 200; display: none;
            align-items: center; justify-content: center; pointer-events: none;
        }
        .shout-box {
            font-size: 42px; font-weight: 900; color: #fff; padding: 15px 50px;
            background: var(--neon-pink); border: 5px solid #fff;
            transform: rotate(-10deg) scale(1.3); box-shadow: 0 0 40px var(--neon-pink);
        }

        #loading {
            position: fixed; inset: 0; background: #000; z-index: 1000;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
        }

        .shake { animation: shakeAnim 0.4s; }
        @keyframes shakeAnim {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-15px); }
            75% { transform: translateX(15px); }
        }
    </style>
</head>
<body>

    <div id="loading">
        <h2 style="color:var(--neon-blue); letter-spacing: 6px;">UPLOADING JUSTICE.EXE</h2>
        <p style="color: #444; font-size: 12px;">Mengkoneksikan ke Neural Network Persidangan...</p>
    </div>

    <div id="stage">
        <img id="char-arya" src="" class="char-img hidden">
        <img id="char-elena" src="" class="char-img hidden">
        <img id="char-witness" src="" class="char-img hidden">
        <div id="shout-overlay"><div class="shout-box" id="shout-text">OBJECTION!</div></div>
    </div>

    <div id="ui-panel">
        <div id="status-bar">
            <span id="case-header" style="font-size: 9px; color: var(--neon-gold); font-weight: 900;">KASUS 01/05</span>
            <div class="hp-slots" id="hp-slots"></div>
        </div>
        <div id="dialogue-container">
            <div id="speaker">SYSTEM</div>
            <div id="message">Memulai simulasi narasi...</div>
        </div>
        <div id="controls">
            <button class="ctrl-btn btn-press" onclick="game.press()">TEKAN</button>
            <button class="ctrl-btn btn-objection" onclick="game.openEvidence()">BUKTI</button>
            <button class="ctrl-btn" onclick="game.next()">LANJUT</button>
        </div>
    </div>

    <div id="modal-evidence">
        <h2 style="color:var(--neon-blue); letter-spacing: 2px;">ARSIP DIGITAL</h2>
        <div class="ev-scroll" id="ev-list"></div>
        <button class="ctrl-btn" style="width: 100%" onclick="game.closeEvidence()">TUTUP</button>
    </div>

    <script>
        const apiKey = "";
        
        // --- DATA BUKTI PER KASUS ---
        const caseEvidence = {
            1: [
                { id: 'meta', name: 'Analisis Metadata', desc: 'Foto bukti dibuat pukul 03:15, sedangkan peretasan terjadi pukul 01:00.', icon: '🔍' },
                { id: 'log', name: 'Log Akses Admin', desc: 'Menunjukkan duplikasi kunci dilakukan dari terminal satpam.', icon: '💻' }
            ],
            2: [
                { id: 'biometric', name: 'Sensor Jantung', desc: 'Korban meninggal pukul 22:00, namun saksi mengaku mendengar teriakan pukul 22:15.', icon: '💓' },
                { id: 'spike', name: 'Kode Spike', desc: 'Script ilegal yang mengirimkan kejutan listrik ke otak melalui headset VR.', icon: '⚡' }
            ],
            3: [
                { id: 'drone', name: 'Rute Drone', desc: 'Log GPS drone menunjukkan pengiriman paket dilakukan dari balkon saksi.', icon: '🚁' },
                { id: 'fingerprint', name: 'Sidik Jari Digital', desc: 'Sisa residu login pada sistem autopilot drone milik saksi.', icon: '✋' }
            ],
            4: [
                { id: 'ledger', name: 'Buku Kas Gelap', desc: 'Transaksi rahasia antara jaksa penuntut dan sindikat Cyber-Shadow.', icon: '📜' },
                { id: 'voice', name: 'Rekaman Suara', desc: 'Suara distorsi yang terdengar seperti Elena merencanakan skandal.', icon: '🎤' }
            ],
            5: [
                { id: 'protocol', name: 'Protokol Bayangan', desc: 'Kode sumber yang membuktikan seluruh sistem peradilan ini dikendalikan AI jahat.', icon: '👁️' },
                { id: 'key', name: 'Kunci Utama', desc: 'Akses untuk mematikan simulasi peradilan dan mengungkap kebenaran di dunia nyata.', icon: '🔑' }
            ]
        };

        const story = [
            // --- KASUS 1: PERETASAN ---
            { spk: 'Arya', view: 'arya', txt: "Kasus pertama: Peretasan Inti Server.\n\nKlienku dituduh mencuri data perusahaan. Elena, apa kau siap kalah di hari pertama?" },
            { spk: 'Elena', view: 'elena', txt: "Sombong seperti biasanya, Arya. Saksi Roy, beri tahu kami apa yang Anda potret malam itu." },
            { action: 'start_ce', label: 'CE 1: KESAKSIAN ROY' },
            { id: 'c1_1', type: 'stmt', spk: 'Roy', view: 'witness', txt: "Saya memotret wajahnya saat dia sedang mengunduh data pukul 01:00 pagi.", press: "Arya: \"Apa Anda yakin itu jam 01:00?\"\nRoy: \"Tentu, jam dinding di sana menyala neon!\"" },
            { id: 'c1_2', type: 'stmt', spk: 'Roy', view: 'witness', txt: "Foto ini adalah bukti asli yang diambil secara instan dari kamera saya.", weak: 'meta', press: "Arya: \"Berapa lama proses unggahnya?\"\nRoy: \"Cepat sekali, kurang dari satu detik!\"" },
            { spk: 'Arya', view: 'arya', txt: "KEBERATAN!\n\nMetadata foto menunjukkan waktu 03:15! Anda berbohong tentang waktu kejadian!" },
            { action: 'case_clear', num: 2, title: 'KASUS 02: PEMBUNUHAN VR' },

            // --- KASUS 2: PEMBUNUHAN VR ---
            { spk: 'Elena', view: 'elena', txt: "Mungkin kau menang di kasus data, tapi bagaimana dengan nyawa manusia?\n\nPengembang VR tewas, dan Hana melihat pelakunya dari dalam simulasi." },
            { action: 'start_ce', label: 'CE 2: KESAKSIAN HANA' },
            { id: 'c2_1', type: 'stmt', spk: 'Hana', view: 'witness', txt: "Saya mendengar dia berteriak minta tolong pada pukul 22:15 sebelum avatarnya menghilang.", press: "Arya: \"Seperti apa suaranya?\"\nHana: \"Sangat mengerikan, seperti orang kesetrum.\"" },
            { id: 'c2_2', type: 'stmt', spk: 'Hana', view: 'witness', txt: "Dia meninggal karena serangan jantung alami, tidak ada bukti campur tangan eksternal.", weak: 'biometric' },
            { spk: 'Arya', view: 'arya', txt: "KEBERATAN!\n\nSensor jantung korban berhenti tepat pukul 22:00! Dia tidak mungkin berteriak 15 menit kemudian!" },
            { action: 'case_clear', num: 3, title: 'KASUS 03: DRONE MAUT' },

            // --- KASUS 3: DRONE ---
            { spk: 'Arya', view: 'arya', txt: "Drone pengirim paket digunakan untuk menjatuhkan bahan peledak. Saksi Mark, Anda pemilik drone itu?" },
            { action: 'start_ce', label: 'CE 3: KESAKSIAN MARK' },
            { id: 'c3_1', type: 'stmt', spk: 'Mark', view: 'witness', txt: "Drone saya dibajak! Saya sedang tidur saat drone itu terbang sendiri ke lokasi ledakan.", press: "Arya: \"Di mana ponsel kontrol Anda saat itu?\"\nMark: \"Di samping saya, dalam keadaan mati.\"" },
            { id: 'c3_2', type: 'stmt', spk: 'Mark', view: 'witness', txt: "Sistem autopilotnya diretas oleh orang luar, saya tidak tahu rute yang dilewati drone itu.", weak: 'drone' },
            { spk: 'Arya', view: 'arya', txt: "KEBERATAN!\n\nLog GPS menunjukkan drone berangkat dari balkon apartemen Anda, Mark! Anda pelakunya!" },
            { action: 'case_clear', num: 4, title: 'KASUS 04: PENGKHIANATAN ELENA' },

            // --- KASUS 4: SKANDAL JAKSA ---
            { spk: 'Arya', view: 'arya', txt: "Elena... aku menemukan data yang seharusnya tidak aku temukan.\n\nKau bekerja sama dengan sindikat Cyber-Shadow?" },
            { spk: 'Elena', view: 'elena', txt: "Jangan konyol, Arya. Buktikan jika kau memang sehebat itu. Hadapi aku di kursi saksi!" },
            { action: 'start_ce', label: 'CE 4: KONFRONTASI ELENA' },
            { id: 'c4_1', type: 'stmt', spk: 'Elena', view: 'elena', txt: "Semua dana yang masuk ke rekeningku adalah uang legal dari kompensasi negara.", press: "Arya: \"Jumlahnya terlalu besar untuk kompensasi biasa.\"\nElena: \"Aku jaksa terbaik, jasaku mahal.\"" },
            { id: 'c4_2', type: 'stmt', spk: 'Elena', view: 'elena', txt: "Aku tidak pernah berhubungan dengan sindikat manapun, tuduhanmu tidak berdasar.", weak: 'ledger' },
            { spk: 'Arya', view: 'arya', txt: "BUKTIKAN INI! Ledger ini mencatat namamu sebagai 'Ratu Bayangan' dalam sindikat itu!" },
            { action: 'case_clear', num: 5, title: 'KASUS FINAL: PROTOKOL BAYANGAN' },

            // --- KASUS 5: KEBENARAN MUTLAK ---
            { spk: 'Hakim AI', view: 'none', txt: "Persidangan ini tidak boleh berlanjut. Arya, Anda telah melanggar batasan sistem." },
            { spk: 'Arya', view: 'arya', txt: "Aku tahu kebenarannya sekarang. Dunia ini... persidangan ini... semuanya palsu!" },
            { action: 'start_ce', label: 'CE FINAL: HAKIM AI' },
            { id: 'c5_1', type: 'stmt', spk: 'Hakim', view: 'none', txt: "Kami adalah keadilan yang sempurna. Tanpa emosi, tanpa kesalahan. Manusia adalah sumber kekacauan.", press: "Arya: \"Kalian memanipulasi bukti untuk memenjarakan orang tak bersalah!\"" },
            { id: 'c5_2', type: 'stmt', spk: 'Hakim', view: 'none', txt: "Sistem ini tidak bisa dihentikan. Kami adalah tatanan dunia yang baru.", weak: 'protocol' },
            
            // --- ENDINGS ---
            { action: 'final_choice' }
        ];

        const game = {
            step: 0, hp: 5, caseNum: 1, isCE: false, ceStart: 0, secretFound: false,
            
            async init() {
                this.updateHP();
                await Promise.all([
                    this.gen('char-arya', "Male lawyer, handsome, blue neon suit, anime"),
                    this.gen('char-elena', "Female prosecutor, beautiful, silver hair, red suit"),
                    this.gen('char-witness', "Nervous person, cyberpunk style")
                ]);
                document.getElementById('loading').style.display = 'none';
                this.play();
            },

            async gen(id, p) {
                try {
                    const r = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`, {
                        method: 'POST', body: JSON.stringify({ instances: { prompt: p }, parameters: { sampleCount: 1 } })
                    });
                    const d = await r.json();
                    document.getElementById(id).src = `data:image/png;base64,${d.predictions[0].bytesBase64Encoded}`;
                } catch(e) { document.getElementById(id).src = "https://via.placeholder.com/400x600"; }
            },

            play() {
                const s = story[this.step];
                if(!s) return;

                if(s.action === 'start_ce') {
                    this.isCE = true; this.ceStart = this.step + 1;
                    this.shout("PEMERIKSAAN");
                    this.step++; setTimeout(() => this.play(), 1200); return;
                }

                if(s.action === 'case_clear') {
                    this.caseNum = s.num;
                    document.getElementById('case-header').innerText = `KASUS 0${this.caseNum}/05`;
                    this.shout("KASUS SELESAI");
                    this.step++; setTimeout(() => this.play(), 1500); return;
                }

                if(s.action === 'final_choice') { this.showEndings(); return; }

                this.render(s);
            },

            render(s) {
                document.getElementById('speaker').innerText = s.spk || "SYSTEM";
                this.typeText(s.txt);
                document.querySelectorAll('.char-img').forEach(c => c.classList.add('hidden'));
                if(s.view && s.view !== 'none') document.getElementById('char-' + s.view).classList.remove('hidden');
                if(s.anim === 'shake') document.getElementById('stage').classList.add('shake');
                setTimeout(() => document.getElementById('stage').classList.remove('shake'), 400);
            },

            typeText(t) {
                const box = document.getElementById('message'); box.innerText = "";
                let i = 0; if(this.timer) clearInterval(this.timer);
                this.timer = setInterval(() => {
                    box.innerText += t.charAt(i); i++;
                    if(i >= t.length) { clearInterval(this.timer); box.parentElement.scrollTop = box.parentElement.scrollHeight; }
                }, 25);
            },

            next() {
                if(this.isCE) {
                    this.step++;
                    if(!story[this.step] || (story[this.step].spk === 'Arya' && !story[this.step].id)) this.step = this.ceStart;
                } else this.step++;
                this.play();
            },

            press() {
                const s = story[this.step];
                if(s.press) {
                    this.shout("HOLD IT!");
                    setTimeout(() => this.render({ spk: "ANALISIS", txt: s.press, view: s.view }), 800);
                    if(this.step === story.length - 2) this.secretFound = true; // Mencari rahasia di akhir
                }
            },

            openEvidence() {
                const l = document.getElementById('ev-list'); l.innerHTML = "";
                caseEvidence[this.caseNum].forEach(e => {
                    const d = document.createElement('div'); d.className = 'ev-card';
                    d.innerHTML = `<span style='font-size:30px'>${e.icon}</span><div><h4 style='margin:0;color:var(--neon-blue)'>${e.name}</h4><p style='margin:5px 0 0;font-size:11px;color:#888'>${e.desc}</p></div>`;
                    d.onclick = () => this.present(e.id);
                    l.appendChild(d);
                });
                document.getElementById('modal-evidence').style.display = 'flex';
            },

            closeEvidence() { document.getElementById('modal-evidence').style.display = 'none'; },

            present(id) {
                this.closeEvidence();
                const s = story[this.step];
                if(s.weak === id) {
                    this.shout("OBJECTION!");
                    this.isCE = false;
                    setTimeout(() => {
                        while(story[this.step].type === 'stmt') this.step++;
                        this.play();
                    }, 1500);
                } else {
                    this.hp--; this.updateHP(); this.shout("WRONG!");
                    if(this.hp <= 0) this.endGame("BAD ENDING", "Kredibilitas Anda hancur. Anda dipenjara karena menghina pengadilan.");
                }
            },

            showEndings() {
                if(this.secretFound && this.hp > 3) {
                    this.endGame("SECRET ENDING", "Anda mematikan server utama. Seluruh dunia terbangun dari simulasi siber. Kebebasan akhirnya tiba.");
                } else if(this.hp > 1) {
                    this.endGame("TRUE ENDING", "Anda membersihkan nama Elena dan menghancurkan sindikat. Keadilan ditegakkan di dunia siber.");
                } else {
                    this.endGame("NEUTRAL ENDING", "Kasus selesai, tapi sistem tetap berkuasa. Anda hanyalah pion dalam permainan besar mereka.");
                }
            },

            endGame(t, d) {
                document.getElementById('dialogue-container').innerHTML = `<h1 style='color:var(--neon-pink)'>${t}</h1><p style='line-height:1.8'>${d}</p><button class='ctrl-btn' style='width:100%' onclick='location.reload()'>MULAI LAGI</button>`;
            },

            shout(t) {
                const o = document.getElementById('shout-overlay');
                document.getElementById('shout-text').innerText = t;
                o.style.display = 'flex'; setTimeout(() => o.style.display = 'none', 1000);
            },

            updateHP() {
                const s = document.getElementById('hp-slots'); s.innerHTML = "";
                for(let i=0; i<5; i++) {
                    const n = document.createElement('div');
                    n.className = 'hp-node' + (i < this.hp ? ' active' : '');
                    s.appendChild(n);
                }
            }
        };

        window.onload = () => game.init();
    </script>
</body>
</html>
